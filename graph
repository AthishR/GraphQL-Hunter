class WAFDetector:
    """Detects and bypasses Web Application Firewalls"""
    
    def __init__(self):
        self.detected_waf = None
        self.bypass_attempted = False
        
    def detect(self, response_text: str, response_headers: dict) -> str:
        """Detect WAF from response"""
        signatures = {
            "Cloudflare": ["cloudflare", "cf-ray", "cf-cache-status"],
            "AWSWAF": ["x-amzn-requestid", "aws-waf", "waf-error"],
            "Akamai": ["x-akamai-transformed", "akamai-origin"],
            "Sucuri": ["sucuri", "x-sucuri"],
            "ModSecurity": ["mod_security", "modsecurity"],
            "F5BigIP": ["bigip", "x-cnection"],
            "Imperva": ["incapsula", "x-iinfo"],
            "Barracuda": ["barracuda", "x-bws"],
        }
        
        combined = response_text + str(response_headers)
        combined = combined.lower()
        
        for waf, patterns in signatures.items():
            for pattern in patterns:
                if pattern.lower() in combined:
                    self.detected_waf = waf
                    return waf
        return None
    
    def get_bypass_headers(self) -> dict:
        """Generate WAF bypass headers"""
        headers = {}
        
        if self.detected_waf in WAF_BYPASS_HEADERS:
            for h in WAF_BYPASS_HEADERS[self.detected_waf]:
                for key, value in h.items():
                    if callable(value):
                        headers[key] = value()
                    else:
                        headers[key] = value
        
        # Add generic bypass headers
        headers.update({
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
            "Accept-Language": "en-US,en;q=0.9",
            "Accept-Encoding": "gzip, deflate, br",
            "Cache-Control": "no-cache",
            "Pragma": "no-cache",
        })
        
        return headers

