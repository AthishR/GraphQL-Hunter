class GQLReconMAX:
    """Main scanner engine with all MAX features"""
    
    def __init__(self, domain: str, config: dict):
        self.domain = domain
        self.config = config
        self.results = []
        self.schemas = []
        self.subdomains = []
        self.waf_detector = WAFDetector()
        self.proxy_rotator = ProxyRotator()
        self.ai_predictor = AIPredictor(domain)
        self.schema_extractor = None
        
        # Setup proxy
        if config.get("tor"):
            self.proxy_rotator.add_tor_proxy()
        
        if config.get("proxies"):
            for proxy in config["proxies"]:
                self.proxy_rotator.add_proxy(proxy)
        
        # Flags
        self.discover_subdomains = config.get("discover_subdomains", False)
        self.use_ai = config.get("ai", False)
        self.bypass_waf = config.get("bypass_waf", False)
        self.extract_schemas = config.get("extract_schemas", False)
        self.distributed_mode = config.get("distributed", False)
        
    async def run(self) -> dict:
        """Run the complete scan"""
        print("\n" + "="*60)
        print(f"GQLRecon MAX v{VERSION}")
        print("="*60)
        print(f"Target: {self.domain}")
        print(f"Features: {', '.join([k for k,v in self.config.items() if v])}")
        print("="*60 + "\n")
        
        # Step 1: Discover subdomains
        if self.discover_subdomains:
            discoverer = SubdomainDiscoverer(self.domain)
            self.subdomains = discoverer.discover()
        
        # Step 2: AI path prediction
        ai_paths = []
        if self.use_ai:
            ai_paths = self.ai_predictor.predict()
        
        # Step 3: Build target list
        targets = self._build_targets(ai_paths)
        print(f"[*] Testing {len(targets)} endpoints...\n")
        
        # Step 4: Scan targets
        if self.distributed_mode:
            self.results = await self._distributed_scan(targets)
        else:
            self.results = await self._scan(targets)
        
        # Step 5: Extract schemas
        if self.extract_schemas:
            await self._extract_schemas()
        
        return self._format_results()
    
    def _build_targets(self, ai_paths: List[str]) -> List[str]:
        """Build list of targets to scan"""
        targets = []
        
        # Add main domain
        domains = [self.domain]
        
        # Add subdomains if discovered
        if self.subdomains:
            domains.extend(self.subdomains)
        
        # Build URLs
        for domain in domains:
            for path in COMMON_PATHS:
                targets.append(f"https://{domain}{path}")
                targets.append(f"http://{domain}{path}")
            
            for path in ai_paths:
                targets.append(f"https://{domain}{path}")
                targets.append(f"http://{domain}{path}")
        
        # Remove duplicates
        return list(set(targets))
    
    async def _scan(self, targets: List[str]) -> List[dict]:
        """Scan all targets"""
        connector = aiohttp.TCPConnector(limit=50)
        
        async with aiohttp.ClientSession(connector=connector) as session:
            self.schema_extractor = SchemaExtractor(session)
            tasks = []
            
            for url in targets:
                task = self._probe(session, url)
                tasks.append(task)
            
            results = await asyncio.gather(*tasks)
            return [r for r in results if r]
    
    async def _distributed_scan(self, targets: List[str]) -> List[dict]:
        """Distributed scanning (simulated)"""
        print("[*] Running in distributed mode...")
        
        # Split targets across worker pools
        chunk_size = max(1, len(targets) // 5)
        chunks = [targets[i:i + chunk_size] for i in range(0, len(targets), chunk_size)]
        
        print(f"[*] {len(chunks)} workers processing {len(targets)} targets...")
        
        # Use ThreadPoolExecutor for parallel processing
        all_results = []
        with ThreadPoolExecutor(max_workers=len(chunks)) as executor:
            futures = []
            for chunk in chunks:
                future = executor.submit(asyncio.run, self._scan(chunk))
                futures.append(future)
            
            for future in futures:
                results = future.result()
                all_results.extend(results)
        
        return all_results
    
    async def _probe(self, session: aiohttp.ClientSession, url: str) -> Optional[dict]:
        """Probe a single endpoint"""
        headers = {}
        proxy = self.proxy_rotator.get_proxy()
        
        if proxy:
            session._proxy = proxy
        
        try:
            # First probe with standard headers
            async with session.post(url, json=INTROSPECTION_QUERY, timeout=8) as resp:
                text = await resp.text()
                score = self._score_response(text)
                
                # Detect WAF
                if self.bypass_waf and resp.status in [403, 429, 503]:
                    waf = self.waf_detector.detect(text, dict(resp.headers))
                    if waf:
                        print(f"[!] WAF detected: {waf} on {url}")
                        # Retry with bypass headers
                        bypass_headers = self.waf_detector.get_bypass_headers()
                        async with session.post(url, json=INTROSPECTION_QUERY, headers=bypass_headers, timeout=8) as resp2:
                            text2 = await resp2.text()
                            score = self._score_response(text2)
                            if score >= 50:
                                return self._format_result(url, "confirmed", score, waf_bypassed=True)
                
                if resp.status == 200 and score >= 70:
                    return self._format_result(url, "confirmed", score)
                
                if score > 30:
                    return self._format_result(url, "suspected", score)
                
        except Exception as e:
            pass
        
        return None
    
    def _score_response(self, text: str) -> int:
        """Calculate confidence score"""
        score = 0
        t = text.lower()
        
        for sig in GRAPHQL_SIGNS:
            if sig.lower() in t:
                score += 20
        
        if "_schema" in t:
            score += 40
        
        if "errors" in t and "Cannot query field" in t:
            score += 30
        
        return min(score, 100)
    
    def _format_result(self, url: str, status: str, score: int, **kwargs) -> dict:
        """Format result entry"""
        result = {
            "url": url,
            "status": status,
            "score": score,
            "timestamp": datetime.now().isoformat(),
            "waf_bypassed": kwargs.get("waf_bypassed", False),
        }
        return result
    
    async def _extract_schemas(self):
        """Extract schemas from confirmed endpoints"""
        print("\n[*] Extracting schemas from confirmed endpoints...")
        
        confirmed = [r for r in self.results if r["status"] == "confirmed"]
        if not confirmed:
            print("[!] No confirmed endpoints to extract schemas from")
            return
        
        async with aiohttp.ClientSession() as session:
            extractor = SchemaExtractor(session)
            
            for result in confirmed:
                url = result["url"]
                schema_result = await extractor.extract(url)
                if schema_result["success"]:
                    self.schemas.append(schema_result)
                    print(f"[+] Schema extracted from {url}")
    
    def _format_results(self) -> dict:
        """Format final results"""
        confirmed = [r for r in self.results if r["status"] == "confirmed"]
        suspected = [r for r in self.results if r["status"] == "suspected"]
        
        return {
            "target": self.domain,
            "timestamp": datetime.now().isoformat(),
            "summary": {
                "total_tested": len(COMMON_PATHS) * (1 + len(self.subdomains)),
                "confirmed": len(confirmed),
                "suspected": len(suspected),
                "subdomains_found": len(self.subdomains),
                "schemas_extracted": len(self.schemas),
            },
            "subdomains": self.subdomains,
            "results": self.results,
            "schemas": self.schemas,
        }

