    if confirmed:
        print(f"\n[✅] CONFIRMED ({len(confirmed)}):")
        for r in confirmed:
            waf = " [WAF Bypassed]" if r.get("waf_bypassed") else ""
            print(f"  🟢 {r['url']} (score={r['score']}){waf}")
    
    suspected = [r for r in results["results"] if r["status"] == "suspected"]
    if suspected:
        print(f"\n[⚠️] SUSPECTED ({len(suspected)}):")
        for r in suspected[:10]:
            print(f"  🟡 {r['url']} (score={r['score']})")
        if len(suspected) > 10:
            print(f"  ... and {len(suspected) - 10} more")
    
    if results["schemas"]:
        print(f"\n[📊] Schemas Extracted:")
        for schema in results["schemas"]:
            print(f"  📋 {schema['endpoint']}")
            if "types" in schema["schema"]:
                count = len(schema["schema"]["types"])
                print(f"     Contains {count} types")
    
    print("\n" + "="*60)

