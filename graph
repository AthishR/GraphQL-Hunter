class SchemaExtractor:
    """Extracts full GraphQL schema"""
    
    def __init__(self, session: aiohttp.ClientSession):
        self.session = session
        
    async def extract(self, url: str, headers: dict = None) -> dict:
        """Extract full schema from endpoint"""
        try:
            async with self.session.post(url, json=FULL_SCHEMA_QUERY, headers=headers or {}, timeout=15) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    if "data" in data and "__schema" in data["data"]:
                        return {
                            "success": True,
                            "schema": data["data"]["__schema"],
                            "endpoint": url
                        }
        except:
            pass
        return {"success": False, "error": "Failed to extract schema"}

