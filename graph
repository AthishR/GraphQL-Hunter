class SubdomainDiscoverer:
    """Discovers subdomains using multiple techniques"""
    
    def __init__(self, domain: str):
        self.domain = domain
        self.subdomains = set()
        
    def discover(self) -> List[str]:
        """Discover subdomains using various methods"""
        print(f"[*] Discovering subdomains for {self.domain}...")
        
        # Method 1: Use subfinder if available
        self._subfinder_discover()
        
        # Method 2: Use amass if available
        self._amass_discover()
        
        # Method 3: DNS brute force (common subdomains)
        self._dns_bruteforce()
        
        # Method 4: Certificate transparency logs
        self._cert_transparency()
        
        print(f"[+] Found {len(self.subdomains)} subdomains")
        return list(self.subdomains)
    
    def _subfinder_discover(self):
        """Use subfinder for discovery"""
        try:
            result = subprocess.run(
                ["subfinder", "-d", self.domain, "-silent"],
                capture_output=True,
                text=True,
                timeout=30
            )
            for line in result.stdout.splitlines():
                if line.strip():
                    self.subdomains.add(line.strip())
        except:
            pass
    
    def _amass_discover(self):
        """Use amass for discovery"""
        try:
            result = subprocess.run(
                ["amass", "enum", "-d", self.domain, "-passive"],
                capture_output=True,
                text=True,
                timeout=60
            )
            for line in result.stdout.splitlines():
                if line.strip() and "." in line:
                    self.subdomains.add(line.strip())
        except:
            pass
    
    def _dns_bruteforce(self):
        """DNS brute force with common subdomains"""
        common = [
            "api", "graphql", "admin", "dev", "test", "stage", "staging",
            "prod", "production", "internal", "private", "public", "mobile",
            "backend", "frontend", "app", "web", "www", "mail", "ftp", "ssh",
            "vpn", "portal", "dashboard", "console", "platform", "service"
        ]
        for sub in common:
            self.subdomains.add(f"{sub}.{self.domain}")
    
    def _cert_transparency(self):
        """Extract from certificate transparency logs"""
        try:
            response = requests.get(
                f"https://crt.sh/?q=%25.{self.domain}&output=json",
                timeout=10
            )
            if response.status_code == 200:
                data = response.json()
                for entry in data:
                    if "name_value" in entry:
                        name = entry["name_value"].lower()
                        if self.domain in name and name.endswith(self.domain):
                            self.subdomains.add(name)
        except:
            pass

