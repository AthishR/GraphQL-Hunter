class AIPredictor:
    """AI-powered endpoint prediction"""
    
    def __init__(self, domain: str):
        self.domain = domain
        self.predicted_paths = []
        
    def predict(self) -> List[str]:
        """Predict possible GraphQL paths"""
        print(f"[*] AI predicting endpoints for {self.domain}...")
        
        predictions = set()
        
        # Extract company/project name from domain
        parts = self.domain.split('.')
        company = parts[0] if len(parts) > 2 else parts[0]
        
        # Apply AI patterns
        for pattern in AI_PATTERNS:
            url1 = pattern.replace("{company}", company)
            url2 = pattern.replace("{project}", company)
            url3 = pattern.replace("{service}", "graphql")
            url4 = pattern.replace("{version}", "v1")
            url5 = pattern.replace("{framework}", "api")
            
            predictions.add(url1)
            predictions.add(url2)
            predictions.add(url3)
            predictions.add(url4)
            predictions.add(url5)
        
        # Context-aware predictions
        context_patterns = [
            f"/{company}/graphql",
            f"/{company}/api/graphql",
            f"/api/{company}",
            f"/{company}-api",
            f"/services/graphql/{company}",
        ]
        predictions.update(context_patterns)
        
        # Framework-specific
        framework_patterns = [
            "/graphql/express",
            "/graphql/spring",
            "/graphql/django",
            "/graphql/rails",
            "/graphql/laravel",
        ]
        predictions.update(framework_patterns)
        
        self.predicted_paths = list(predictions)
        print(f"[+] AI predicted {len(self.predicted_paths)} additional paths")
        return self.predicted_paths

