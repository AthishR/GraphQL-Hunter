        "threads": args.threads,
        "quiet": args.quiet,
    }
    
    # Show feature flags
    if not args.quiet:
        print("\n⚙️ Configuration:")
        for key, value in config.items():
            if key not in ["proxies", "threads", "quiet"]:
                print(f"  {key}: {value}")
        if args.proxies:
            print(f"  proxies: {len(args.proxies)} proxies")
        print(f"  threads: {args.threads}")
    
    # Run scanner
    scanner = GQLReconMAX(args.domain, config)
    results = asyncio.run(scanner.run())
    
    # Output
    if not args.quiet:
        print_results(results)
    else:
        # Quiet mode - just print confirmed endpoints
        confirmed = [r for r in results["results"] if r["status"] == "confirmed"]
        for r in confirmed:
            print(r["url"])
    
    # Save results
    if args.output:
        save_results(results, args.output)
    
    # Return exit code
    if results["summary"]["confirmed"] > 0:
        sys.exit(0)
    else:
        sys.exit(1)

if __name__ == "__main__":
    main()
